# Build output (any package, any depth)
build/
traces/*
.trace
.coverage*
Pub.*.toml

# Move package config — regenerated per machine, not tracked
Move.lock
Move.toml

# Deployment records — environment-specific, updated locally only
deployments.json

# Developer tooling / docs / generated assets — local only, not part of contract code
skills/
docs/
scripts/
# template/ source IS tracked (coin template = contract code); its build/ and
# Move.lock/Move.toml are covered by the rules above.
